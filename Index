<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Para ti ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  background: #0d0d0d;
  color: #f5f5f5;
  font-family: 'Playfair Display', serif;
  overflow: hidden;
}

/* Pantalla inicio */
#startScreen {
  position: fixed;
  width: 100%;
  height: 100%;
  background: #0d0d0d;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 18px;
  cursor: pointer;
  z-index: 10;
  letter-spacing: 1px;
}

/* Contenedor */
.container {
  max-width: 650px;
  margin: auto;
  padding: 40px;
  text-align: center;
  opacity: 0;
  filter: blur(10px);
  transition: all 1.5s ease;
}

.container.show {
  opacity: 1;
  filter: blur(0);
}

/* Imagen */
.photo {
  width: 180px;
  height: 180px;
  object-fit: cover;
  border-radius: 50%;
  margin-bottom: 20px;
  opacity: 0;
  transform: scale(0.9);
  transition: all 1.5s ease;
}

.photo.show {
  opacity: 1;
  transform: scale(1);
}

/* Texto */
h1 {
  font-size: 32px;
  margin-bottom: 25px;
}

p {
  font-size: 18px;
  line-height: 1.7;
  opacity: 0;
  transform: translateY(10px);
  transition: all 1s ease;
}

p.show {
  opacity: 1;
  transform: translateY(0);
}

/* Corazón */
.heart {
  font-size: 22px;
  margin-top: 20px;
  animation: beat 1.5s infinite;
}

@keyframes beat {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}
</style>
</head>

<body>

<div id="startScreen" onclick="startExperience()">
  Toca para comenzar ❤️
</div>

<div class="container" id="content">

  <!-- FOTO -->
  <img src="foto.jpg" class="photo" id="photo">

  <h1>Para ti</h1>

  <p id="typing"></p>

  <p>Desde que llegaste a mi vida, todo se siente diferente… más bonito, más real.</p>

  <p>Me haces sonreír sin razón y pensar en ti más de lo que imaginé.</p>

  <p>Gracias por estar, por quedarte, por ser tú.</p>

  <p>Te quiero muchísimo.</p>

  <div class="heart">❤️</div>
</div>

<audio id="music" loop>
  <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
function startExperience() {
  document.getElementById("startScreen").style.display = "none";

  const audio = document.getElementById("music");
  audio.play();

  const content = document.getElementById("content");
  content.classList.add("show");

  setTimeout(() => {
    document.getElementById("photo").classList.add("show");
  }, 800);

  typeWriter();

  const paragraphs = document.querySelectorAll("p:not(#typing)");
  paragraphs.forEach((p, i) => {
    setTimeout(() => {
      p.classList.add("show");
    }, 2000 + (i * 600));
  });
}

/* TEXTO INICIAL (puedes cambiarlo aquí) */
const text = "Holadanita...";
let i = 0;

function typeWriter() {
  if (i < text.length) {
    document.getElementById("typing").innerHTML += text.charAt(i);
    i++;
    setTimeout(typeWriter, 80);
  }
}
</script>

</body>
</html>
